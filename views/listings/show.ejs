    const listingLocation = <%- JSON.stringify(listing.location) %>;
</script>

<style>
  .detail-container {
    max-width: 800px;
    margin: 2rem auto;
  }
  
  .listing-title {
    font-weight: 800;
    color: #222222;
    margin-bottom: 1.5rem;
  }

  .show-card-custom {
    border: none !important;
    background-color: transparent !important;
  }

  .show-img-custom {
    height: 420px;
    width: 100%;
    object-fit: cover;
    border-radius: 1.25rem !important;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    margin-bottom: 1.5rem;
  }

  .owner-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #717171;
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }

  .listing-desc-custom {
    font-size: 1.05rem;
    line-height: 1.6;
    color: #333333;
    margin-bottom: 1.5rem;
  }

  .price-tag-custom {
    font-size: 1.35rem;
    font-weight: 800;
    color: #222222;
    margin-bottom: 0.5rem;
  }

  .location-info {
    font-size: 0.95rem;
    color: #555555;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  /* Buttons Section */
  .action-buttons {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .btn-edit-custom {
    background-color: #de3250 !important;
    color: white !important;
    border: none !important;
    font-weight: 600;
    border-radius: 0.5rem;
    padding: 0.6rem 2rem;
    transition: all 0.2s ease;
  }

  .btn-edit-custom:hover {
    background-color: #ff385c !important;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(222, 50, 80, 0.2);
  }

  .btn-delete-custom {
    background-color: #222222 !important;
    color: white !important;
    border: none !important;
    font-weight: 600;
    border-radius: 0.5rem;
    padding: 0.6rem 2rem;
    transition: all 0.2s ease;
  }

  .btn-delete-custom:hover {
    background-color: #000000 !important;
    transform: translateY(-1px);
  }

  /* Review Section */
  .review-section-title {
    font-weight: 700;
    color: #222222;
    margin-bottom: 1.25rem;
  }

  .review-card-custom {
    border: 1px solid rgba(0, 0, 0, 0.08) !important;
    border-radius: 0.85rem !important;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
    padding: 1.25rem;
    margin-bottom: 1rem;
    background: #fafafa;
    transition: all 0.2s ease;
  }

  .review-card-custom:hover {
    background: #ffffff;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.06);
    border-color: rgba(0, 0, 0, 0.12) !important;
  }

  .review-author {
    font-size: 0.95rem;
    font-weight: 700;
    color: #222222;
    margin-bottom: 0.35rem;
  }

  .review-comment {
    font-size: 0.95rem;
    color: #484848;
    line-height: 1.5;
  }

  .btn-delete-review {
    background-color: #222222;
    color: white;
    border: none;
    font-size: 0.8rem;
    font-weight: 600;
    border-radius: 0.35rem;
    padding: 0.35rem 0.85rem;
    transition: background-color 0.2s;
  }

  .btn-delete-review:hover {
    background-color: #ff385c;
  }

  /* Form Styling */
  .review-form-custom .form-control {
    border-radius: 0.5rem;
    border: 1px solid #cccccc;
    padding: 0.75rem;
    font-size: 0.95rem;
  }

  .review-form-custom .form-control:focus {
    border-color: #de3250;
    box-shadow: 0 0 0 0.2rem rgba(222, 50, 80, 0.15);
  }

  .btn-submit-review {
    background-color: #222222 !important;
    color: white !important;
    border: none !important;
    font-weight: 600;
    padding: 0.6rem 1.5rem;
    border-radius: 0.5rem;
    transition: background-color 0.2s;
  }

  .btn-submit-review:hover {
    background-color: #000000 !important;
  }

  /* Leaflet Map Frame */
  .map-container-custom {
    border-radius: 1.25rem;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.06);
    border: 1px solid rgba(0,0,0,0.08);
  }

  #map {
    height: 350px;
    width: 100%;
  }

  @media (max-width: 767.98px) {
    .show-img-custom {
      height: 280px;
    }
  }
</style>

<div class="row">
    <div class="col-md-8 offset-md-2 col-12 mt-3">
        <h3 class="listing-title"><%= listing.title %></h3>
        
        <div class="card show-card-custom">
            <img src="<%= listing.image.url %>" class="card-img-top show-img-custom" alt="listing_image">
            <div class="card-body p-0">
                <div class="owner-badge">
                    <i class="fa-solid fa-circle-user fa-lg"></i>
                    <span>Hosted by <%= listing.owner.username %></span>
                </div>
                <hr>
                <p class="listing-desc-custom"><%= listing.description %></p>
                <div class="price-tag-custom">
                    &#8377; <%= listing.price?.toLocaleString("en-IN") ?? "N/A" %> <span style="font-size: 1rem; font-weight: 400; color: #717171;">/ night</span>
                </div>
                <div class="location-info">
                    <i class="fa-solid fa-location-dot" style="color: #de3250;"></i>
                    <span><%= listing.location %>, <%= listing.country %></span>
                </div>
            </div>
        </div>

        <% if(currUser && currUser._id.equals(listing.owner._id)) {%>
        <div class="action-buttons">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-edit-custom">Edit Listing</a>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
                <button class="btn btn-delete-custom">Delete Listing</button>
            </form>
        </div>
        <% } else { %>
            <hr class="my-4">
        <% } %>

        <!-- Review Form -->
        <% if(currUser) { %>
        <div class="mb-4">
            <h4 class="review-section-title">Leave a Review</h4>
            <form action="/listings/<%= listing.id %>/reviews" method="post" novalidate class="needs-validation review-form-custom">
                <div class="mb-3">
                    <label class="form-label font-weight-bold" for="rating">Rating</label>
                    <fieldset class="starability-coinFlip">
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="comment">Comment</label>
                    <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control" required placeholder="Tell us about your experience..."></textarea>
                    <div class="invalid-feedback">
                        Please provide a comment for your review.
                    </div>
                </div>
                <button type="submit" class="btn btn-submit-review">Submit Review</button>
            </form>
        </div>
        <hr class="my-4">
        <% } %>
        
        <!-- Display Reviews -->
        <% if(listing.reviews.length > 0) { %> 
        <div class="mb-4">
            <h4 class="review-section-title">All Reviews</h4>
            <div class="row row-cols-md-2 row-cols-1 g-3">
                <% for(review of listing.reviews) {%>
                    <div class="col">
                        <div class="card review-card-custom h-100">
                            <div class="card-body p-0 d-flex flex-column justify-content-between h-100">
                                <div>
                                    <div class="review-author d-flex align-items-center gap-2">
                                        <i class="fa-regular fa-user-circle"></i>
                                        <span>@<%= review.author.username %></span>
                                    </div>
                                    <p class="starability-result mb-2" data-rating="<%= review.rating %>">
                                        Rated: <%= review.rating %> stars
                                    </p>
                                    <p class="review-comment"><%= review.comment %></p>
                                </div>
                                <% if(currUser && currUser._id.equals(review.author._id)) { %>
                                <form class="mt-2" method="post" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                    <button class="btn btn-delete-review">Delete</button>
                                </form>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
            <hr class="my-4">
        </div>
        <% } %>

        <!-- Location Section -->
        <div class="mb-5">
            <h4 class="review-section-title">Where you'll be</h4>
            <div class="map-container-custom">
                <div id="map"></div>
            </div>
        </div>
    </div>
</div>

<script src="/js/map.js"></script>